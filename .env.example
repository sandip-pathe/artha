# Core
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=

# Optional voice tuning
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=nova

# Optional if using Google Vision with service account file
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json

# Optional template settings
DEEPGRAM_API_KEY=

# Optional frontend CORS controls
# Comma-separated explicit origins, e.g. https://artha-nu.vercel.app,https://your-custom-domain.com
CORS_ALLOW_ORIGINS=
# Regex fallback for preview deployments
CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
