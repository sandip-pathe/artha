# Core
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
OPENAI_API_KEY=

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Optional voice tuning
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=nova

# Optional if using Google Vision with service account file
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json

# Optional template settings (if you enable template sends)
WHATSAPP_PAYTM_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=en
